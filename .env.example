# Copia este fichero a `.env` y rellena los valores.
# `.env` está en .gitignore: nunca subas credenciales al repositorio.

# --- Obligatorio ---
# Clave de API de OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Opcional (se muestran los valores por defecto) ---
OPENAI_MODEL=gpt-4o-mini

# Temperatura baja = evaluaciones más reproducibles entre ejecuciones.
TEMPERATURE=0.2

# Timeout por llamada al proveedor, en segundos.
REQUEST_TIMEOUT=60

# Reintentos ante fallos transitorios del proveedor.
MAX_RETRIES=2

# Tamaño máximo del PDF subido, en bytes (5 MB).
MAX_UPLOAD_BYTES=5242880

# Límite de caracteres del CV enviados al modelo (acota el coste por análisis).
MAX_CV_CHARS=30000

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
